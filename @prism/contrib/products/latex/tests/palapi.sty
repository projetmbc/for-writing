% -- Creation [L3] -- %

%%%
% prototype::
%     #1 :
%     #2 :
%
%     :action:
%%%
\cs_new_protected:Nn \palette_create_from_rgb:nn {
  \palette_new:n { #1 }

  \clist_map_inline:nn { #2 }{
    \palette_add_color:nn { #1 } { ##1 }
  }
}


%%%
% prototype::
%     #1 :
%     #2 :
%
%     :action:
%%%
% \extractcolorspecs{color}{model-cmd}{color-cmd}
% Extracts the color specification of color and puts it into model-cmd $\rangle$ and $ color-cmd $\rangle$, respectively.
%
% \convertcolorspec{model}{spec}{target model}{cmd}
% Converts a color, given by the spec in model model, into target model and stores the new color specification in \cmd. target model must be of type nummodel, whereas model may also be ‘named’, in which case spec is simply the name of the color.
\cs_new_protected:Nn \palette_create_from_name:nn {
  \palette_new:n { #1 }

  \clist_map_inline:nn { #2 }{
    \group_begin:
      \extractcolorspecs
        { ##1 }
        { \@pal@model@ }
        { \@pal@col@spec@}

      \convertcolorspec
        { \@pal@model@ }
        { \@pal@col@spec@ }
        { rgb }
        { \@rgb@xcolor@ }

      \tl_gset:Nx \g_tmpa_tl { \@rgb@xcolor@ }
    \group_end:

    \exp_args:NnV \palette_add_color:nn { #1 } { \g_tmpa_tl }
  }
}


\cs_new_protected:Nn \palette_new:n {
  \seq_new:c { g_palette_#1_seq }
}


%%%
% prototype::
%     #1 :
%     #2 :
%
%     :action:
%%%
\cs_new_protected:Nn \palette_add_color:nn {
  \seq_gput_right:cn { g_palette_#1_seq }{ #2 }

  \int_set:Nn \l_tmpa_int {
    \seq_count:c { g_palette_#1_seq }
  }

  \definecolor{palette@#1@\int_use:N\l_tmpa_int}
              {rgb}{#2}
}


%%%
% prototype::
%     #1 :
%
%     :return:
%%%
\cs_new:Nn \palette_size:n {
  \seq_count:c { g_palette_#1_seq }
}


%%%
% prototype::
%     #1 :
%
%     :return:
%%%
\cs_new:Nn \palette_get_color_name:nn {
  palette@#1@#2
}

