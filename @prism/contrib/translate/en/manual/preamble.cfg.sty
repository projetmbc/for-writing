\begin{luacode*}
BUILD_TIKZ = true


function drawSimPals(names, suffix)
  for _ , palname in ipairs(names) do
    local g = graph:new{
      window = {-5, 15, -5, 5},
      bbox   = false,
      border = false
    }

    g:Linewidth(1)

    local A     = Z(-5, 4)
    local h, dh = Z(0, -1), Z(0, -1.1)
    local L, N  = 12.5, 150
    local dl    = L / N

    local pal = getPal(palname)

    for k = 1, N do
      local color = palette(pal, (k - 1) / (N - 1))

      g:Drectangle(
        A, A + h, A + h + dl,
           "color = " .. color
        .. ", fill = " .. color
      )

      A = A+dl
    end

    g:Drectangle(A, A + h, A + h - L)

    g:Dlabel(
      "\\quad\\large\\texttt{\\bfseries " .. palname .. "}",
      A + h / 2,
      {pos = "E"}
    )

    local tkzfile = "_luadraw/similar-cluster-" .. suffix .. "-" .. palname .. ".tkz"

    if BUILD_TIKZ then
      g:Savetofile(tkzfile)
    end

    tex.sprint("\\input{" .. tkzfile .. "}")

--     g:Sendtotex()

    tex.sprint("\\smallskip\\par")
  end
end


function drawSpectrum(pal, suffix)
  local g = graph:new{
    window = {-5, 5, -5, 5},
    bbox   = false,
    border = false
  }

  g:Linewidth(1)

  local A, h, dh = Z(-5, 4), Z(0, -1), Z(0, -.75)
  local L, N = 5, 150
  local dl = L / N

  for k = 1, N do
    local color = palette(pal, (k - 1) / (N - 1))

    g:Drectangle(
      A, A+h, A+h+dl,
      "color = " .. color .. ", fill = " .. color
    )

    A = A+dl
  end

  g:Drectangle(A, A+h, A+h-L)

  local tkzfile = "_luadraw/spectrum-catego-" .. suffix .. ".tkz"

  if BUILD_TIKZ then
    g:Savetofile(tkzfile)
  end

  tex.sprint("\\input{" .. tkzfile .. "}")
end


function drawPalette(pal, suffix)
  local palsize  = #pal
  local paldim   = .5
  local paldelta = .2

  local g = graph:new{
    window = {-100, 100, -5, 5},
    bbox   = false
  }

  g:Linewidth(2)

  local A = Z(-20, 4)
  local v = Z(0, -paldim)

  for k = 1, palsize do
    local color = rgb(pal[k])

    g:Drectangle(
      A, A + paldim, A + paldim + v,
      "color = black, fill = " .. color
    )

    A = A + paldim + paldelta
  end

  local tkzfile = "_luadraw/palette-catego-" .. suffix .. ".tkz"

  if BUILD_TIKZ then
    g:Savetofile(tkzfile)
  end

  tex.sprint("\\input{" .. tkzfile .. "}")
end


function drawCategoPals(names, suffix)
  for i, data in ipairs(names) do
    local name, credit = data[1], data[2]
    local pal          = getPal(name)
    local _suffix      = suffix .. "-" .. i

    tex.print("\\parbox[c]{0.3\\linewidth}{")
    drawSpectrum(pal, _suffix)
    tex.print("}")

    tex.print("\\hfill")

    tex.print(
           "\\parbox[c]{3.25cm}{"
        .. "\\centering\\textbf{\\texttt{"
        .. name
        .. "}} \\\\ {\\footnotesize\\color{Grey}"
        .. credit
        .. "}}"
    )

    tex.print("\\hfill")

    tex.print("\\parbox[c]{0.45\\linewidth}{")
    drawPalette(pal, _suffix)
    tex.print("}")

    tex.print("")
    tex.print("\\vspace{3pt}")
  end
end
\end{luacode*}
